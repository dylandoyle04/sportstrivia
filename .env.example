# Copy this file to .env.local and fill in real values.
# .env.local is gitignored (matches *.local in .gitignore); this file is safe to commit.

# balldontlie.io — free tier requires an API key.
# No VITE_ prefix: this is read server-side only by the Vite dev proxy, never shipped to the browser.
BALLDONTLIE_API_KEY=

# football-data.org — add when ready (also server-side only)
# FOOTBALL_DATA_API_KEY=
